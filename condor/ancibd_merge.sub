universe   = vanilla
executable = /bin/bash
arguments  = "-lc 'cd $(ROOT) && RUN_ID=$(RUN_ID) ./scripts/merge_batch_outputs.sh'"

request_cpus   = 1
request_memory = 2GB
request_disk   = 1GB

log    = $(RUNS_ROOT)/$(RUN_ID)/logs/condor/merge.log
output = $(RUNS_ROOT)/$(RUN_ID)/logs/condor/merge.out
error  = $(RUNS_ROOT)/$(RUN_ID)/logs/condor/merge.err

notification = never

queue
