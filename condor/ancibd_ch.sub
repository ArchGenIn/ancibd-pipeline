universe   = vanilla
executable = /bin/bash
arguments  = "-lc 'cd $(ROOT) && RUN_ID=$(RUN_ID) ./scripts/run_chrom.sh $(CH)'"

request_cpus   = 1
request_memory = 4GB
request_disk   = 5GB

log    = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_ch$(CH).log
output = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_ch$(CH).out
error  = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_ch$(CH).err

notification = never

queue
