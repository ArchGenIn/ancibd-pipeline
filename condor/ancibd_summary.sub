universe   = vanilla
executable = /bin/bash
arguments  = "-lc 'cd $(ROOT) && RUN_ID=$(RUN_ID) ./scripts/run_summary.sh $(CH_RANGE)'"

request_cpus   = 1
request_memory = 2GB
request_disk   = 1GB

log    = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_summary.log
output = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_summary.out
error  = $(RUNS_ROOT)/$(RUN_ID)/logs/condor_summary.err

notification = never

queue
