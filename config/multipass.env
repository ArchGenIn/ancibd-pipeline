# Template config for the **local cloud emulator** described in docs/local_cloud_emulation.md
#
# Copy to config/local.env and edit input templates as needed.

# Path to the Apptainer SIF image (shared path inside the VMs)
SIF_IMAGE="/opt/ancibd-pipeline/containers/ancibd_0.8_ubuntu22.sif"

# Shared filesystems (emulating gluster mounts)
#
# If you want “everything on SSD”, put inputs here too:
DATA_ROOT="/mnt/ssd_gluster_volume/data"

# If you prefer to keep large immutable inputs on the “HDD” mount, use instead:
# DATA_ROOT="/mnt/hdd_gluster_volume/data"

# Recommended for the emulator: keep derived data + runs on the “SSD” mount.
RUNS_ROOT="/mnt/ssd_gluster_volume/runs"
HDF5_ROOT="${RUNS_ROOT}/hdf5_cache"

# Chromosomes to run, expressed as "start-end".
CH_RANGE="20-20"

# Demo-style naming templates (edit to match your real data)
# Use "{CH}" placeholder for chromosome number.
PREFIX="example_hazelton"
VCF_TEMPLATE="${DATA_ROOT}/vcf.raw/example_hazelton_chr{CH}.vcf.gz"
MARKER_TEMPLATE="${DATA_ROOT}/filters/snps_bcftools_ch{CH}.csv"
AF_TEMPLATE="${DATA_ROOT}/afs/v51.1_1240k_AF_ch{CH}.tsv"
MAP_PATH="${DATA_ROOT}/map/v51.1_1240k.snp"

# Where to store the prebuilt HDF5 per chromosome.
# ancIBD expects the filename to contain "ch{CH}.h5".
HDF5_TEMPLATE="${HDF5_ROOT}/${PREFIX}.ch{CH}.h5"

# Optional: keep the intermediate filtered VCF (1240k sites only).
VCF_1240K_TEMPLATE="${HDF5_ROOT}/${PREFIX}.ch{CH}.1240k.vcf.gz"

# --- batch / scale-out knobs ---
BATCH_SIZE="500"
