# Copy to config/local.env and edit.
# The scripts will source config/local.env.

# Path to the Apptainer SIF image (absolute recommended)
SIF_IMAGE="$(pwd)/containers/ancibd_0.8_ubuntu22.sif"

# Immutable input root (absolute recommended)
DATA_ROOT="$(pwd)/data"

# Runs root (absolute recommended)
RUNS_ROOT="$(pwd)/runs"

# Derived HDF5 root (absolute recommended).
# This is where the VCF/BCF -> HDF5 conversion step writes its outputs.
# Recommended: keep it on fast local storage (SSD).
HDF5_ROOT="${RUNS_ROOT}/hdf5_cache"

# Chromosomes to run, expressed as "start-end".
# For the small demo dataset, chr20 is enough.
CH_RANGE="20-20"

# Dataset naming templates (edit to match your real data)
# Use "{CH}" placeholder for chromosome number.
PREFIX="example_hazelton."
VCF_TEMPLATE="${DATA_ROOT}/vcf.raw/example_hazelton_chr{CH}.vcf.gz"
MARKER_TEMPLATE="${DATA_ROOT}/filters/snps_bcftools_ch{CH}.csv"
MAP_PATH="${DATA_ROOT}/map/v51.1_1240k.snp"

# Optional per-chromosome *reference* allele-frequency TSVs.
# These are only used when building HDF5s with:
#   ./ancibd-pipeline build-hdf5 ... --with-raf
# and are stored into the HDF5 as: variants/RAF
RAF_TEMPLATE="${DATA_ROOT}/afs/v51.1_1240k_AF_ch{CH}.tsv"

# --- HDF5 naming ---
# You can either:
#  A) set explicit templates (most flexible), or
#  B) set naming components (prefix/suffix/label) and let the scripts assemble paths.
#
# A) Explicit templates (contain {CH}). Uncomment to use.
# HDF5_TEMPLATE="${HDF5_ROOT}/${PREFIX}ch{CH}.h5"
# VCF_1240K_TEMPLATE="${HDF5_ROOT}/${PREFIX}ch{CH}.1240k.vcf.gz"
#
# B) Naming components (assembled as: ${HDF5_ROOT}/${HDF5_PREFIX}${HDF5_CH_LABEL}{CH}${HDF5_SUFFIX}${HDF5_EXT})
# Defaults (if you leave these unset):
#   HDF5_PREFIX="${PREFIX}"   (or empty if PREFIX is empty)
#   HDF5_CH_LABEL="ch"
#   HDF5_SUFFIX=""
#   HDF5_EXT=".h5"
#   VCF_1240K_SUFFIX=".1240k.vcf.gz"
#
# Example matching a file name like: chr2.merged.1240k.20250825.h5
# HDF5_PREFIX=""; HDF5_CH_LABEL="chr"; HDF5_SUFFIX=".merged.1240k.20250825"

HDF5_PREFIX="${PREFIX}"
HDF5_CH_LABEL="ch"
HDF5_SUFFIX=""
HDF5_EXT=".h5"

# Optional: keep the intermediate filtered VCF (1240k sites only).
VCF_1240K_SUFFIX=".1240k.vcf.gz"

# --- batch / scale-out knobs ---
# Batch size for IID preloading (see README). 500-1000 tends to be reasonable.
BATCH_SIZE="500"

# Optional: keep Apptainer runtime dirs off shared filesystems in HPC.
# APPTAINER_CACHEDIR="$HOME/.cache/apptainer"
# APPTAINER_TMPDIR="$HOME/.tmp/apptainer"
