Bootstrap: docker
From: ubuntu:22.04

%post
    set -e

    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        build-essential \
        bcftools \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

    python3 -m pip install --no-cache-dir -U pip setuptools wheel
    python3 -m pip install --no-cache-dir --root-user-action=ignore "ancIBD==0.8"
    python3 -m pip install --no-cache-dir --root-user-action=ignore matplotlib

    command -v ancIBD-run
    command -v ancIBD-summary

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec "$@"
