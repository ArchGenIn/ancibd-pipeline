#!/usr/bin/env bash
set -euo pipefail

# ancibd-pipeline
#
# Tight wrapper around ancIBD with two execution modes:
#   - baseline: dumb/slow/obviously-correct reference
#   - prod:     concurrent batchpair workflow (HTCondor DAGMan)
#
# Plus the minimum supporting commands:
#   - build/validate HDF5
#   - progress checks
#   - run directory creation

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=scripts/lib.sh
source "$ROOT/scripts/lib.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./ancibd-pipeline <command> [args...]

Chromosome range resolution (all commands that accept CH_RANGE):
  1) positional CH_RANGE argument (e.g. 1-22)
  2) CH_RANGE environment variable
  3) CH_RANGE in config/local.env
  4) fallback 1-22

Core workflow:
  baseline [CH_RANGE] [--pcol AF_ALL|RAF]
      Dumb, slow, reference mode.
      Runs ancIBD per chromosome for CH_RANGE, then runs ancIBD-summary.
      Outputs: runs/<RUN_ID>/out/merged/{ch_all.tsv,ibd_ind.tsv}
      Requires RUN_ID.

  prod [CH_RANGE] [--pcol AF_ALL|RAF]
      Concurrent production mode (batchpairs + merge) using HTCondor DAGMan.
      Outputs: runs/<RUN_ID>/out/merged/{ch_all.tsv,ibd_ind.tsv}
      Requires RUN_ID.

Allele-frequency modes:
  --pcol AF_ALL (default)
      Use *sample* allele frequencies stored in the HDF5 at variants/AF_ALL.

  --pcol RAF
      Use *reference* allele frequencies stored in the HDF5 at variants/RAF.
      This requires building HDF5s with --with-raf.

Inputs:
  build-hdf5 [CH_RANGE] [--force] [--with-raf] [--raf-path PATH]
      Build per-chromosome HDF5 inputs under HDF5_ROOT.
      Does NOT require RUN_ID.
      If --with-raf is given, per-chrom reference AF TSVs are merged into
      variants/RAF (default template from config/local.env: RAF_TEMPLATE or AF_TEMPLATE).
      Use --raf-path to override that template (may include {CH}).

  build-hdf5-condor [CH_RANGE] [--force] [--with-raf] [--raf-path PATH]
      Same as build-hdf5, but submits one job per chromosome via HTCondor.
      Does NOT require RUN_ID.

  validate-hdf5 [CH_RANGE]
      Validate the HDF5s expected for CH_RANGE.
      Does NOT require RUN_ID.

Utilities:
  new-run <TAG>
      Create a new run directory and print the RUN_ID.

  check-batch [--missing-only] [--write-missing PATH]
      Report progress for the prod workflow of RUN_ID.

Notes:
  - Configure the pipeline by copying config/example.env to config/local.env.
  - Build the container image once with ./containers/build.sh
USAGE
}

normalize_pcol() {
  local v="$1"
  v="${v^^}"
  case "$v" in
    AF_ALL|AFALL|AF) echo "AF_ALL" ;;
    RAF) echo "RAF" ;;
    *) die "Invalid --pcol value: $1 (expected AF_ALL or RAF)" ;;
  esac
}

choose_ch_range() {
  # Args: <cli> <env> <cfg>
  local cli="$1" env="$2" cfg="$3"
  if [[ -n "$cli" ]]; then
    echo "$cli"
  elif [[ -n "$env" ]]; then
    echo "$env"
  elif [[ -n "$cfg" ]]; then
    echo "$cfg"
  else
    echo "1-22"
  fi
}

write_run_options() {
  # Persist run-level options for reproducibility and for Condor jobs.
  # Args: <RUN_DIR> <PCOL>
  local run_dir="$1" pcol="$2"
  mkdir -p "$run_dir/meta"
  {
    echo "PCOL=$pcol"
  } > "$run_dir/meta/options.env"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  -h|--help|help|"")
    usage
    exit 0
    ;;

  new-run)
    tag="${1:-}"
    [[ -n "$tag" ]] || die "usage: ./ancibd-pipeline new-run <TAG>"
    exec "$ROOT/scripts/new_run.sh" "$tag"
    ;;

  build-hdf5)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"
    FORCE=0
    WITH_RAF=0
    RAF_PATH_OVERRIDE=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --force)
          FORCE=1; shift ;;
        --with-raf)
          WITH_RAF=1; shift ;;
        --raf-path)
          [[ -n "${2:-}" ]] || die "--raf-path requires a value"
          RAF_PATH_OVERRIDE="$2"; WITH_RAF=1; shift 2 ;;
        *)
          if [[ "$1" =~ ^[0-9]+-[0-9]+$ ]]; then
            CH_RANGE_CLI="$1"; shift
          else
            die "Unknown arg for build-hdf5: $1"
          fi
          ;;
      esac
    done

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    EXTRA_ARGS=()
    if [[ $FORCE -eq 1 ]]; then
      EXTRA_ARGS+=(--force)
    fi
    if [[ $WITH_RAF -eq 1 ]]; then
      EXTRA_ARGS+=(--with-raf)
      if [[ -n "$RAF_PATH_OVERRIDE" ]]; then
        EXTRA_ARGS+=(--raf-path "$RAF_PATH_OVERRIDE")
      fi
    fi

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      "$ROOT/scripts/build_hdf5.sh" "$ch" "${EXTRA_ARGS[@]}"
    done
    ;;

  build-hdf5-condor)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"
    FORCE=0
    WITH_RAF=0
    RAF_PATH_OVERRIDE=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --force)
          FORCE=1; shift ;;
        --with-raf)
          WITH_RAF=1; shift ;;
        --raf-path)
          [[ -n "${2:-}" ]] || die "--raf-path requires a value"
          RAF_PATH_OVERRIDE="$2"; WITH_RAF=1; shift 2 ;;
        *)
          if [[ "$1" =~ ^[0-9]+-[0-9]+$ ]]; then
            CH_RANGE_CLI="$1"; shift
          else
            die "Unknown arg for build-hdf5-condor: $1"
          fi
          ;;
      esac
    done

    load_config
    require_cmd condor_submit

    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    mkdir -p "$HDF5_ROOT/logs"

    FORCE_ARG=""
    if [[ $FORCE -eq 1 ]]; then
      FORCE_ARG="--force"
    fi

    RAF_ARGS=""
    if [[ $WITH_RAF -eq 1 ]]; then
      if [[ -n "$RAF_PATH_OVERRIDE" ]]; then
        RAF_ARGS="--with-raf --raf-path $RAF_PATH_OVERRIDE"
      else
        RAF_ARGS="--with-raf"
      fi
    fi

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      condor_submit \
        -append "ROOT=$ROOT" \
        -append "HDF5_ROOT=$HDF5_ROOT" \
        -append "CH=$ch" \
        -append "FORCE_ARG=$FORCE_ARG" \
        -append "RAF_ARGS=$RAF_ARGS" \
        "$ROOT/condor/ancibd_hdf5.sub"
    done
    ;;

  validate-hdf5)
    CH_RANGE_CLI="${1:-}"
    CH_RANGE_ENV="${CH_RANGE:-}"
    shift || true

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    exec "$ROOT/scripts/validate_hdf5_range.sh" "$CH_RANGE_USE"
    ;;

  baseline)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"

    if [[ "${1:-}" =~ ^[0-9]+-[0-9]+$ ]]; then
      CH_RANGE_CLI="$1"; shift
    fi

    PCOL="AF_ALL"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pcol)
          [[ -n "${2:-}" ]] || die "--pcol requires a value"
          PCOL="$(normalize_pcol "$2")"; shift 2
          ;;
        *)
          die "Unknown arg for baseline: $1"
          ;;
      esac
    done

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    RUN_ID="${RUN_ID:?set RUN_ID env var (use ./ancibd-pipeline new-run <tag>)}"

    RUN_DIR="$RUNS_ROOT/$RUN_ID"
    [[ -e "$RUN_DIR/DONE" ]] && die "Run is DONE: $RUN_DIR"
    if [[ -d "$RUN_DIR/work" ]] && find "$RUN_DIR/work" -type f -print -quit | grep -q .; then
      die "Run workdir is not empty: $RUN_DIR/work\nCreate a new RUN_ID with: ./ancibd-pipeline new-run <tag>"
    fi
    if [[ -d "$RUN_DIR/out" ]] && find "$RUN_DIR/out" -type f -print -quit | grep -q .; then
      die "Run outdir is not empty: $RUN_DIR/out\nCreate a new RUN_ID with: ./ancibd-pipeline new-run <tag>"
    fi

    mkdir -p "$RUN_DIR"/{meta,work,out,logs}
    "$ROOT/scripts/write_manifest.sh"
    write_run_options "$RUN_DIR" "$PCOL"

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      "$ROOT/scripts/run_chrom.sh" "$ch"
    done

    exec "$ROOT/scripts/run_summary.sh" "$CH_RANGE_USE"
    ;;

  prod)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"

    if [[ "${1:-}" =~ ^[0-9]+-[0-9]+$ ]]; then
      CH_RANGE_CLI="$1"; shift
    fi

    PCOL="AF_ALL"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pcol)
          [[ -n "${2:-}" ]] || die "--pcol requires a value"
          PCOL="$(normalize_pcol "$2")"; shift 2
          ;;
        *)
          die "Unknown arg for prod: $1"
          ;;
      esac
    done

    load_config
    require_cmd condor_submit_dag

    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    RUN_ID="${RUN_ID:?set RUN_ID env var (use ./ancibd-pipeline new-run <tag>)}"

    RUN_DIR="$RUNS_ROOT/$RUN_ID"
    [[ -e "$RUN_DIR/DONE" ]] && die "Run is DONE: $RUN_DIR"
    mkdir -p "$RUN_DIR"/{meta,work,out,logs,logs/condor}
    "$ROOT/scripts/write_manifest.sh"
    write_run_options "$RUN_DIR" "$PCOL"

    # Ensure IID list and batchpairs exist before submitting.
    "$ROOT/scripts/make_iid_list.sh" >/dev/null
    "$ROOT/scripts/make_batchpairs.sh" >/dev/null

    DAG_DIR="$RUNS_ROOT/$RUN_ID/condor/batch"
    mkdir -p "$DAG_DIR"
    cp "$ROOT/condor/ancibd_batchpair.sub" "$ROOT/condor/ancibd_merge.sub" "$DAG_DIR/"

    DAG_FILE="$DAG_DIR/batch.dag"
    PAIRS_FILE="$RUN_DIR/meta/batchpairs.tsv"
    [[ -s "$PAIRS_FILE" ]] || die "Missing or empty pairs file: $PAIRS_FILE"

    # Build one DAG node per batchpair.
    # This is crucial: DAGMan dependencies are defined between *nodes*, and a single
    # node which queues many procs can cause the merge step to run too early.
    bp_nodes=()

    {
      echo "# Auto-generated by ancibd-pipeline prod"
      echo "# Repo root: $ROOT"
      echo "# RUN_ID: $RUN_ID"
      echo "# CH_RANGE: $CH_RANGE_USE"
      echo

      while IFS=$'\t' read -r b1 b2 rest; do
        [[ -n "${b1:-}" ]] || continue
        node="BP_$(printf 'b%03d_b%03d' "$b1" "$b2")"
        bp_nodes+=("$node")
        echo "JOB $node ancibd_batchpair.sub"
        echo "VARS $node ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\" CH_RANGE=\"$CH_RANGE_USE\" B1=\"$b1\" B2=\"$b2\""
        echo
      done < "$PAIRS_FILE"

      echo "JOB MERGE ancibd_merge.sub"
      echo "VARS MERGE ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\""
      echo
    } > "$DAG_FILE"

    # Add dependencies: all batchpair nodes -> MERGE.
    # Split into chunks to avoid extremely long single lines for large runs.
    if [[ ${#bp_nodes[@]} -eq 0 ]]; then
      die "No batchpair nodes were generated from: $PAIRS_FILE"
    fi

    {
      chunk=()
      for node in "${bp_nodes[@]}"; do
        chunk+=("$node")
        if [[ ${#chunk[@]} -ge 40 ]]; then
          echo "PARENT ${chunk[*]} CHILD MERGE"
          chunk=()
        fi
      done
      if [[ ${#chunk[@]} -gt 0 ]]; then
        echo "PARENT ${chunk[*]} CHILD MERGE"
      fi
    } >> "$DAG_FILE"

    (cd "$DAG_DIR" && condor_submit_dag "$(basename "$DAG_FILE")")
    ;;

  check-batch)
    exec "$ROOT/scripts/check_batch_status.sh" "$@"
    ;;

  *)
    die "Unknown command: $cmd (run './ancibd-pipeline --help')"
    ;;
esac
