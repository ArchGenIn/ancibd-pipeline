#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$ROOT/scripts/lib.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./ancibd-pipeline <command> [args...]

Chromosome range resolution:
  1) positional CH_RANGE argument
  2) CH_RANGE environment variable
  3) CH_RANGE in config/local.env
  4) fallback 1-22

Commands:
  baseline [CH_RANGE] [--pcol AF_ALL|RAF|AF_REF]
  prod [CH_RANGE] [--pcol AF_ALL|RAF|AF_REF]
  prod-incremental [CH_RANGE] --delta-iids PATH --delta-kind new|analyzed [--pcol AF_ALL|RAF|AF_REF]
  build-hdf5 [CH_RANGE] [--force] [--with-ref-af] [--ref-af-path PATH]
  build-hdf5-condor [CH_RANGE] [--force] [--with-ref-af] [--ref-af-path PATH]
  validate-hdf5 [CH_RANGE]
  new-run <TAG>
  check-batch [--missing-only] [--write-missing PATH]

Allele-frequency fields:
  AF_ALL   sample AFs computed during HDF5 build
  RAF      RAF imported from the filtered VCF/BCF
  AF_REF   standalone reference-AF TSVs baked into the HDF5
USAGE
}

normalize_pcol() {
  local v="${1^^}"
  case "$v" in
    AF_ALL|RAF|AF_REF) echo "$v" ;;
    *) die "Invalid --pcol value: $1 (expected AF_ALL, RAF, or AF_REF)" ;;
  esac
}

choose_ch_range() {
  local cli="$1" env="$2" cfg="$3"
  if [[ -n "$cli" ]]; then
    echo "$cli"
  elif [[ -n "$env" ]]; then
    echo "$env"
  elif [[ -n "$cfg" ]]; then
    echo "$cfg"
  else
    echo "1-22"
  fi
}

write_run_options() {
  local run_dir="$1" pcol="$2"
  mkdir -p "$run_dir/meta"
  printf 'PCOL=%s
' "$pcol" > "$run_dir/meta/options.env"
}

dir_has_entries() {
  local dir="$1"
  [[ -d "$dir" ]] && find "$dir" -mindepth 1 -print -quit | grep -q .
}

prepare_run_dirs() {
  local run_dir="$1"
  [[ -e "$run_dir/DONE" ]] && die "Run is DONE: $run_dir"
  if dir_has_entries "$run_dir/work"; then
    die "Run workdir is not empty: $run_dir/work
Create a new RUN_ID with: ./ancibd-pipeline new-run <tag>"
  fi
  if dir_has_entries "$run_dir/out"; then
    die "Run outdir is not empty: $run_dir/out
Create a new RUN_ID with: ./ancibd-pipeline new-run <tag>"
  fi
  mkdir -p "$run_dir"/{meta,work,out,logs,logs/condor}
  "$ROOT/scripts/write_manifest.sh"
}

submit_prod_dag() {
  local run_dir="$1" ch_range_use="$2"
  local jobs_file="$run_dir/meta/pairjobs.tsv"
  [[ -s "$jobs_file" ]] || die "Missing or empty jobs file: $jobs_file"

  local dag_dir="$run_dir/condor/batch"
  mkdir -p "$dag_dir"
  cp "$ROOT/condor/ancibd_batchpair.sub" "$ROOT/condor/ancibd_merge.sub" "$dag_dir/"

  local dag_file="$dag_dir/batch.dag"
  local -a job_nodes=()
  {
    echo "# Auto-generated by ancibd-pipeline prod"
    echo "# Repo root: $ROOT"
    echo "# RUN_ID: $RUN_ID"
    echo "# CH_RANGE: $ch_range_use"
    echo

    while IFS=$'\t' read -r job_id _rest; do
      [[ -n "${job_id:-}" ]] || continue
      [[ "$job_id" == "job_id" ]] && continue
      node="JOB_${job_id}"
      job_nodes+=("$node")
      echo "JOB $node ancibd_batchpair.sub"
      echo "CATEGORY $node BP"
      printf 'VARS %s ROOT="%s" RUNS_ROOT="%s" RUN_ID="%s" CH_RANGE="%s" JOB_ID="%s" REQ_CPUS="%s" REQ_MEM="%s" REQ_DISK="%s"\n' "$node" "$ROOT" "$RUNS_ROOT" "$RUN_ID" "$ch_range_use" "$job_id" "$BP_REQUEST_CPUS" "$BP_REQUEST_MEMORY" "$BP_REQUEST_DISK"
      echo
    done < "$jobs_file"

    if [[ -n "${BP_MAXJOBS:-}" && "$BP_MAXJOBS" != "0" ]]; then
      echo "MAXJOBS BP $BP_MAXJOBS"
      echo
    fi

    echo "JOB MERGE ancibd_merge.sub"
    printf 'VARS MERGE ROOT="%s" RUNS_ROOT="%s" RUN_ID="%s"\n' "$ROOT" "$RUNS_ROOT" "$RUN_ID"
    echo
  } > "$dag_file"

  [[ ${#job_nodes[@]} -gt 0 ]] || die "No pairjob nodes were generated from: $jobs_file"

  {
    chunk=()
    for node in "${job_nodes[@]}"; do
      chunk+=("$node")
      if [[ ${#chunk[@]} -ge 40 ]]; then
        echo "PARENT ${chunk[*]} CHILD MERGE"
        chunk=()
      fi
    done
    if [[ ${#chunk[@]} -gt 0 ]]; then
      echo "PARENT ${chunk[*]} CHILD MERGE"
    fi
  } >> "$dag_file"

  (cd "$dag_dir" && condor_submit_dag "$(basename "$dag_file")")
}

cmd="${1:-}"
shift || true

case "$cmd" in
  -h|--help|help|"")
    usage
    exit 0
    ;;

  new-run)
    tag="${1:-}"
    [[ -n "$tag" ]] || die "usage: ./ancibd-pipeline new-run <TAG>"
    exec "$ROOT/scripts/new_run.sh" "$tag"
    ;;

  build-hdf5)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"
    FORCE=0
    WITH_REF_AF=0
    REF_AF_PATH_OVERRIDE=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --force)
          FORCE=1; shift ;;
        --with-ref-af)
          WITH_REF_AF=1; shift ;;
        --ref-af-path)
          [[ -n "${2:-}" ]] || die "$1 requires a value"
          REF_AF_PATH_OVERRIDE="$2"; WITH_REF_AF=1; shift 2 ;;
        *)
          if [[ "$1" =~ ^[0-9]+-[0-9]+$ ]]; then
            CH_RANGE_CLI="$1"; shift
          else
            die "Unknown arg for build-hdf5: $1"
          fi
          ;;
      esac
    done

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    EXTRA_ARGS=()
    [[ $FORCE -eq 1 ]] && EXTRA_ARGS+=(--force)
    if [[ $WITH_REF_AF -eq 1 ]]; then
      EXTRA_ARGS+=(--with-ref-af)
      [[ -n "$REF_AF_PATH_OVERRIDE" ]] && EXTRA_ARGS+=(--ref-af-path "$REF_AF_PATH_OVERRIDE")
    fi

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      "$ROOT/scripts/build_hdf5.sh" "$ch" "${EXTRA_ARGS[@]}"
    done
    ;;

  build-hdf5-condor)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"
    FORCE=0
    WITH_REF_AF=0
    REF_AF_PATH_OVERRIDE=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --force)
          FORCE=1; shift ;;
        --with-ref-af)
          WITH_REF_AF=1; shift ;;
        --ref-af-path)
          [[ -n "${2:-}" ]] || die "$1 requires a value"
          REF_AF_PATH_OVERRIDE="$2"; WITH_REF_AF=1; shift 2 ;;
        *)
          if [[ "$1" =~ ^[0-9]+-[0-9]+$ ]]; then
            CH_RANGE_CLI="$1"; shift
          else
            die "Unknown arg for build-hdf5-condor: $1"
          fi
          ;;
      esac
    done

    load_config
    require_cmd condor_submit
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"

    mkdir -p "$HDF5_ROOT/logs"

    FORCE_ARG=""
    REF_AF_ARGS=""
    [[ $FORCE -eq 1 ]] && FORCE_ARG="--force"
    if [[ $WITH_REF_AF -eq 1 ]]; then
      if [[ -n "$REF_AF_PATH_OVERRIDE" ]]; then
        REF_AF_ARGS="--with-ref-af --ref-af-path $REF_AF_PATH_OVERRIDE"
      else
        REF_AF_ARGS="--with-ref-af"
      fi
    fi

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      condor_submit         -append "ROOT=$ROOT"         -append "HDF5_ROOT=$HDF5_ROOT"         -append "CH=$ch"         -append "FORCE_ARG=$FORCE_ARG"         -append "REF_AF_ARGS=$REF_AF_ARGS"         "$ROOT/condor/ancibd_hdf5.sub"
    done
    ;;

  validate-hdf5)
    CH_RANGE_CLI="${1:-}"
    CH_RANGE_ENV="${CH_RANGE:-}"
    shift || true

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"
    exec "$ROOT/scripts/validate_hdf5_range.sh" "$CH_RANGE_USE"
    ;;

  baseline)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"

    if [[ "${1:-}" =~ ^[0-9]+-[0-9]+$ ]]; then
      CH_RANGE_CLI="$1"; shift
    fi

    PCOL="AF_ALL"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pcol)
          [[ -n "${2:-}" ]] || die "--pcol requires a value"
          PCOL="$(normalize_pcol "$2")"; shift 2 ;;
        *)
          die "Unknown arg for baseline: $1" ;;
      esac
    done

    load_config
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"
    RUN_ID="${RUN_ID:?set RUN_ID env var (use ./ancibd-pipeline new-run <tag>)}"

    RUN_DIR="$RUNS_ROOT/$RUN_ID"
    prepare_run_dirs "$RUN_DIR"
    write_run_options "$RUN_DIR" "$PCOL"

    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE_USE")
    for ((ch=CH_START; ch<=CH_END; ch++)); do
      "$ROOT/scripts/run_chrom.sh" "$ch"
    done

    exec "$ROOT/scripts/run_summary.sh" "$CH_RANGE_USE"
    ;;

  prod)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"

    if [[ "${1:-}" =~ ^[0-9]+-[0-9]+$ ]]; then
      CH_RANGE_CLI="$1"; shift
    fi

    PCOL="AF_ALL"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pcol)
          [[ -n "${2:-}" ]] || die "--pcol requires a value"
          PCOL="$(normalize_pcol "$2")"; shift 2 ;;
        *)
          die "Unknown arg for prod: $1" ;;
      esac
    done

    load_config
    require_batchpair_requests
    require_cmd condor_submit_dag
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"
    RUN_ID="${RUN_ID:?set RUN_ID env var (use ./ancibd-pipeline new-run <tag>)}"
    RUN_DIR="$RUNS_ROOT/$RUN_ID"

    prepare_run_dirs "$RUN_DIR"
    write_run_options "$RUN_DIR" "$PCOL"
    "$ROOT/scripts/make_iid_list.sh" >/dev/null
    "$ROOT/scripts/make_pairjobs.sh" --mode all >/dev/null
    submit_prod_dag "$RUN_DIR" "$CH_RANGE_USE"
    ;;

  prod-incremental)
    CH_RANGE_CLI=""
    CH_RANGE_ENV="${CH_RANGE:-}"
    DELTA_IIDS=""
    DELTA_KIND=""

    if [[ "${1:-}" =~ ^[0-9]+-[0-9]+$ ]]; then
      CH_RANGE_CLI="$1"; shift
    fi

    PCOL="AF_ALL"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pcol)
          [[ -n "${2:-}" ]] || die "--pcol requires a value"
          PCOL="$(normalize_pcol "$2")"; shift 2 ;;
        --delta-iids)
          [[ -n "${2:-}" ]] || die "--delta-iids requires a value"
          DELTA_IIDS="$2"; shift 2 ;;
        --delta-kind)
          [[ -n "${2:-}" ]] || die "--delta-kind requires a value"
          DELTA_KIND="$2"; shift 2 ;;
        *)
          die "Unknown arg for prod-incremental: $1" ;;
      esac
    done

    [[ -n "$DELTA_IIDS" ]] || die "prod-incremental requires --delta-iids PATH"
    [[ -n "$DELTA_KIND" ]] || die "prod-incremental requires --delta-kind new|analyzed"

    load_config
    require_batchpair_requests
    require_cmd condor_submit_dag
    CH_RANGE_USE="$(choose_ch_range "$CH_RANGE_CLI" "$CH_RANGE_ENV" "${CH_RANGE:-}")"
    RUN_ID="${RUN_ID:?set RUN_ID env var (use ./ancibd-pipeline new-run <tag>)}"
    RUN_DIR="$RUNS_ROOT/$RUN_ID"

    prepare_run_dirs "$RUN_DIR"
    write_run_options "$RUN_DIR" "$PCOL"
    "$ROOT/scripts/make_iid_list.sh" >/dev/null
    "$ROOT/scripts/make_pairjobs.sh"       --mode incremental       --delta-iids "$DELTA_IIDS"       --delta-kind "$DELTA_KIND" >/dev/null
    submit_prod_dag "$RUN_DIR" "$CH_RANGE_USE"
    ;;

  check-batch)
    exec "$ROOT/scripts/check_batch_status.sh" "$@"
    ;;

  *)
    die "Unknown command: $cmd (run './ancibd-pipeline --help')"
    ;;
esac
