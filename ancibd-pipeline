#!/usr/bin/env bash
set -euo pipefail

# Top-level CLI wrapper for ancibd-pipeline.
#
# Philosophy:
# - Keep the implementation in the existing scripts/ and condor/ templates.
# - Provide a stable, user-facing command surface:
#     ancibd-pipeline run-chrom ...
#     ancibd-pipeline run-chrom-condor ...
#     ancibd-pipeline run-chrom-dag ...
#     ancibd-pipeline run-batch ...
#     ancibd-pipeline run-batch-condor ...
#     ancibd-pipeline run-batch-dag ...

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=scripts/lib.sh
source "$ROOT/scripts/lib.sh"

usage() {
  cat <<'EOF'
Usage:
  ancibd-pipeline <command> [args...]

Commands:
  run-chrom [CH_RANGE] [--summarize]
      Run all chromosomes for CH_RANGE (default: CH_RANGE env or 1-22).
      Use --summarize *after* all per-chromosome runs finished to generate the summary.
      Requires RUN_ID env var.

  run-chrom-condor [CH_RANGE] [--summarize]
      Submit all chromosome jobs via HTCondor for CH_RANGE (default: CH_RANGE env or 1-22).
      Use --summarize *after* all per-chromosome jobs finished to submit the summary job.
      Requires RUN_ID env var.

  run-chrom-dag [CH_RANGE]
      Generate a per-run DAG directory and submit a DAGMan workflow:
      chromosome jobs for CH_RANGE (default: CH_RANGE env or 1-22) -> summary.
      Requires RUN_ID env var.

  run-batch [CH_RANGE]
      Run all batch pairs for CH_RANGE (default: CH_RANGE env or 1-22) and merge outputs.
      Requires RUN_ID env var.

  run-batch-condor [CH_RANGE] [--merge]
      Submit one job per (batch_i, batch_j) pair via HTCondor for CH_RANGE (default: CH_RANGE env or 1-22).
      Use --merge *after* all batchpair jobs finished to submit the merge job.
      Requires RUN_ID env var.

  run-batch-dag [CH_RANGE]
      Generate a per-run DAG directory and submit a DAGMan workflow:
      batchpair jobs for CH_RANGE (default: CH_RANGE env or 1-22) -> merge.
      Requires RUN_ID env var.

Notes:
  - All commands assume you have a configured config/local.env (copy from
    config/example.env).
  - Most modes require a run directory created beforehand:
        RUN_ID="$(./scripts/new_run.sh demo)"; export RUN_ID
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  -h|--help|help|"")
    usage
    exit 0
    ;;

  run-chrom)
    CH_RANGE="${CH_RANGE:-1-22}"
    SUMMARIZE=0

    # Accept:
    #   run-chrom
    #   run-chrom <CH_RANGE>
    #   run-chrom <CH_RANGE> --summarize
    #   run-chrom --summarize
    if [[ "${1:-}" == "--summarize" ]]; then
      SUMMARIZE=1
      shift
    elif [[ -n "${1:-}" ]]; then
      CH_RANGE="$1"
      shift
    fi
    if [[ "${1:-}" == "--summarize" ]]; then
      SUMMARIZE=1
      shift
    fi

    RUN_ID="${RUN_ID:?set RUN_ID env var (use scripts/new_run.sh)}"

    if [[ $SUMMARIZE -eq 1 ]]; then
      exec "$ROOT/scripts/run_summary.sh" "$CH_RANGE"
    else
      read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE")
      for ((ch=CH_START; ch<=CH_END; ch++)); do
        "$ROOT/scripts/run_chrom.sh" "$ch"
      done

      echo "NOTE: When all per-chromosome runs finished, generate the summary with:" >&2
      echo "  ancibd-pipeline run-chrom $CH_RANGE --summarize" >&2
    fi
    ;;

  run-chrom-condor)
    CH_RANGE="${CH_RANGE:-1-22}"
    SUMMARIZE=0

    # Accept:
    #   run-chrom-condor
    #   run-chrom-condor <CH_RANGE>
    #   run-chrom-condor <CH_RANGE> --summarize
    #   run-chrom-condor --summarize
    if [[ "${1:-}" == "--summarize" ]]; then
      SUMMARIZE=1
      shift
    elif [[ -n "${1:-}" ]]; then
      CH_RANGE="$1"
      shift
    fi
    if [[ "${1:-}" == "--summarize" ]]; then
      SUMMARIZE=1
      shift
    fi

    load_config
    require_cmd condor_submit
    RUN_ID="${RUN_ID:?set RUN_ID env var (use scripts/new_run.sh)}"

    if [[ $SUMMARIZE -eq 1 ]]; then
      condor_submit \
        -append "ROOT=$ROOT" \
        -append "RUNS_ROOT=$RUNS_ROOT" \
        -append "RUN_ID=$RUN_ID" \
        -append "CH_RANGE=$CH_RANGE" \
        "$ROOT/condor/ancibd_summary.sub"
    else
      read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE")
      for ((ch=CH_START; ch<=CH_END; ch++)); do
        condor_submit \
          -append "ROOT=$ROOT" \
          -append "RUNS_ROOT=$RUNS_ROOT" \
          -append "RUN_ID=$RUN_ID" \
          -append "CH=$ch" \
          "$ROOT/condor/ancibd_ch.sub"
      done

      echo "NOTE: When all per-chromosome jobs finished, submit the summary job with:" >&2
      echo "  ancibd-pipeline run-chrom-condor $CH_RANGE --summarize" >&2
    fi
    ;;

  run-chrom-dag)
    CH_RANGE="${1:-${CH_RANGE:-1-22}}"
    shift || true
    load_config
    require_cmd condor_submit_dag
    RUN_ID="${RUN_ID:?set RUN_ID env var (use scripts/new_run.sh)}"

    # Parse and expand range.
    read -r CH_START CH_END < <(parse_ch_range "$CH_RANGE")

    # Keep DAGMan artifacts out of the repo root, and keep chrom vs batch DAGs separate.
    DAG_DIR="$RUNS_ROOT/$RUN_ID/condor/chrom"
    mkdir -p "$DAG_DIR"

    # Copy submit templates into the per-run DAG directory.
    cp "$ROOT/condor/ancibd_ch.sub" "$ROOT/condor/ancibd_summary.sub" "$DAG_DIR/"

    DAG_FILE="$DAG_DIR/chrom.dag"
    {
      echo "# Auto-generated by ancibd-pipeline run-chrom-dag"
      echo "# Repo root: $ROOT"
      echo "# RUN_ID: $RUN_ID"
      echo "# CH_RANGE: $CH_RANGE"
      echo

      parents=()
      for ((ch=CH_START; ch<=CH_END; ch++)); do
        # DAG node names must be simple identifiers.
        node="CH$(printf '%02d' "$ch")"
        parents+=("$node")
        echo "JOB $node ancibd_ch.sub"
        echo "VARS $node ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\" CH=\"$ch\""
        echo
      done

      echo "JOB SUM ancibd_summary.sub"
      echo "VARS SUM ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\" CH_RANGE=\"$CH_RANGE\""
      echo

      echo -n "PARENT"
      for node in "${parents[@]}"; do
        echo -n " $node"
      done
      echo " CHILD SUM"
    } > "$DAG_FILE"

    (cd "$DAG_DIR" && condor_submit_dag "$(basename "$DAG_FILE")")
    ;;

  run-batch)
    exec "$ROOT/scripts/run_all_batches_local.sh" "$@"
    ;;

  run-batch-condor)
    CH_RANGE="${CH_RANGE:-1-22}"
    MERGE=0

    # Accept:
    #   run-batch-condor
    #   run-batch-condor <CH_RANGE>
    #   run-batch-condor <CH_RANGE> --merge
    #   run-batch-condor --merge
    if [[ "${1:-}" == "--merge" ]]; then
      MERGE=1
      shift
    elif [[ -n "${1:-}" ]]; then
      CH_RANGE="$1"
      shift
    fi
    if [[ "${1:-}" == "--merge" ]]; then
      MERGE=1
      shift
    fi

    load_config
    require_cmd condor_submit
    RUN_ID="${RUN_ID:?set RUN_ID env var (use scripts/new_run.sh)}"

    # Ensure batchpairs exist before submitting.
    "$ROOT/scripts/make_batchpairs.sh" >/dev/null

    if [[ $MERGE -eq 1 ]]; then
      condor_submit \
        -append "ROOT=$ROOT" \
        -append "RUNS_ROOT=$RUNS_ROOT" \
        -append "RUN_ID=$RUN_ID" \
        "$ROOT/condor/ancibd_merge.sub"
    else
      condor_submit \
        -append "ROOT=$ROOT" \
        -append "RUNS_ROOT=$RUNS_ROOT" \
        -append "RUN_ID=$RUN_ID" \
        -append "CH_RANGE=$CH_RANGE" \
        "$ROOT/condor/ancibd_batchpair.sub"

      echo "NOTE: When all batchpair jobs finished, submit the merge job with:" >&2
      echo "  ancibd-pipeline run-batch-condor $CH_RANGE --merge" >&2
    fi
    ;;

  run-batch-dag)
    CH_RANGE="${1:-${CH_RANGE:-1-22}}"
    shift || true
    load_config
    require_cmd condor_submit_dag
    RUN_ID="${RUN_ID:?set RUN_ID env var (use scripts/new_run.sh)}"

    # Ensure batchpairs exist before submitting.
    "$ROOT/scripts/make_batchpairs.sh" >/dev/null

    # Keep DAGMan artifacts out of the repo root, and keep chrom vs batch DAGs separate.
    DAG_DIR="$RUNS_ROOT/$RUN_ID/condor/batch"
    mkdir -p "$DAG_DIR"

    # Copy submit templates into the per-run DAG directory.
    cp "$ROOT/condor/ancibd_batchpair.sub" "$ROOT/condor/ancibd_merge.sub" "$DAG_DIR/"

    DAG_FILE="$DAG_DIR/batch.dag"
    {
      echo "# Auto-generated by ancibd-pipeline run-batch-dag"
      echo "# Repo root: $ROOT"
      echo "# RUN_ID: $RUN_ID"
      echo "# CH_RANGE: $CH_RANGE"
      echo

      echo "JOB BATCH ancibd_batchpair.sub"
      echo "VARS BATCH ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\" CH_RANGE=\"$CH_RANGE\""
      echo

      echo "JOB MERGE ancibd_merge.sub"
      echo "VARS MERGE ROOT=\"$ROOT\" RUNS_ROOT=\"$RUNS_ROOT\" RUN_ID=\"$RUN_ID\""
      echo

      echo "PARENT BATCH CHILD MERGE"
    } > "$DAG_FILE"

    (cd "$DAG_DIR" && condor_submit_dag "$(basename "$DAG_FILE")")
    ;;

  *)
    die "Unknown command: $cmd (run 'ancibd-pipeline --help')"
    ;;
esac
